    "nyc-vingelli.html": {
      "settings": {
        "main": false,
        "title": "New York: 2025 Vingelli Subway Map",
        "meta_descr": "MetroMaps.org | The Internet's Atlas of Transit Maps",
        "header_custom": "<script src=\"assets-openseadragon/openseadragon.min.js\"></script>",
        "footer_custom": "<body style=\"background-color:#000000;\">",
        "html_before": "",
        "order": "136"
      },
      "components": [
        {
          "_customTemplate": true,
          "_afterNavbarItem": false,
          "_customHTML": "<!-- Type valid HTML here -->\n\n   <div class=\"image-block m-auto\">\n        <div id=\"openseadragon\"> </div>\n\n[JS_CODE_0]</div>",
          "_customCSS": "/* Type valid CSS here */\n\n#openseadragon {\n    width: 100vw;\n    height: 100vh;\n}\n",
          "alias": "code-editor",
          "_tags": [
            "Extension"
          ],
          "_name": "pro.custom-html",
          "_sourceTheme": "mobirise5",
          "_JSplaceholders": [
            "<script>\n    \n    \nvar viewer = OpenSeadragon({\n    id: \"openseadragon\",\n    prefixUrl: \"assets-openseadragon/images/\",\n    tileSources: {\n        type: \"image\",\n        url: \"https://i.imgur.com/YOa630j.jpg\"\n    }\n});\n    function resizeViewer() {\n    var viewerElement = document.getElementById(\"openseadragon\");\n    viewerElement.style.width = window.innerWidth + \"px\";\n    viewerElement.style.height = window.innerHeight + \"px\";\n}\n\nwindow.addEventListener(\"resize\", resizeViewer);\nresizeViewer();\n\n    \n</script>"
          ],
          "_PHPplaceholders": [],
          "_params": {},
          "_anchor": "custom-html-1z"
        }
      ]
    },
