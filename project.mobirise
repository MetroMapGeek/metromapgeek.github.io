    "full-page-iframe.html": {
      "settings": {
        "title": "MetroMaps.org",
        "order": "1",
        "meta_descr": "MetroMaps.org | The Internet's Atlas of Transit Maps"
      },
      "components": [
        {
          "_customTemplate": true,
          "_afterNavbarItem": false,
          "_customHTML": "<!-- Type valid HTML here -->\n<div class=\"fullscreen-map\">\n  <iframe src=\"https://umap.openstreetmap.fr/en/map/metromapsorg_1203972#2/0.0/-35.0\" allowfullscreen=\"\"></iframe>\n</div>\n\n<iframe style=\"width: 100%; height: 300px; border: 0;\" allowfullscreen=\"\" allow=\"geolocation\" src=\"//umap.openstreetmap.fr/en/map/metromapsorg_1203972?scaleControl=false&amp;miniMap=false&amp;scrollWheelZoom=false&amp;zoomControl=true&amp;editMode=disabled&amp;moreControl=true&amp;searchControl=null&amp;tilelayersControl=null&amp;embedControl=null&amp;datalayersControl=true&amp;onLoadPanel=none&amp;captionBar=false&amp;captionMenus=true\"></iframe><p><a href=\"//umap.openstreetmap.fr/en/map/metromapsorg_1203972?scaleControl=false&amp;miniMap=false&amp;scrollWheelZoom=true&amp;zoomControl=true&amp;editMode=disabled&amp;moreControl=true&amp;searchControl=null&amp;tilelayersControl=null&amp;embedControl=null&amp;datalayersControl=true&amp;onLoadPanel=none&amp;captionBar=false&amp;captionMenus=true\">See full screen</a></p>\n\n\n[JS_CODE_0]\n\n",
          "_customCSS": "/* Type valid CSS here */\n\n.fullscreen-map, \n.fullscreen-map iframe {\n  width: 100%;\n  height: 100vh;   /* full viewport height */\n  margin: 0;\n  padding: 0;\n  border: none;\n}\n\n\n.fullscreen-map {\n  padding: 0 !important;\n}\n.mbr-section {\n  padding: 0 !important;\n}\n\n\n/* Prevent mobile browsers from re-rendering the iframe constantly */\niframe[src*=\"umap\"] {\n    image-rendering: auto !important;\n    transform: translateZ(0);\n    backface-visibility: hidden;\n    will-change: transform;\n}\n\n",
          "alias": "code-editor",
          "_tags": [
            "Extension"
          ],
          "_name": "pro.custom-html",
          "_sourceTheme": "startm5",
          "_JSplaceholders": [
            "<script>\ndocument.addEventListener(\"DOMContentLoaded\", function () {\n    const iframe = document.querySelector('iframe[src*=\"umap\"]');\n    if (!iframe) return;\n\n    iframe.onload = function () {\n        try {\n            const mapWindow = iframe.contentWindow;\n            const L = mapWindow.L;\n\n            if (!L) return;\n\n            // Force high-res tiles and disable mobile downscaling\n            L.Browser.retina = true;\n\n            // Reduce tile reloads when panning/zooming\n            L.Map.mergeOptions({\n                fadeAnimation: false,\n                zoomAnimation: false,\n                markerZoomAnimation: false\n            });\n\n            // Make tile layers keep more tiles in memory\n            L.TileLayer.prototype.options.updateWhenIdle = true;\n            L.TileLayer.prototype.options.keepBuffer = 6;\n        } catch (err) {\n            console.warn(\"Could not access uMap iframe:\", err);\n        }\n    };\n});\n</script>"
          ],
          "_PHPplaceholders": [],
          "_params": {},
          "_anchor": "custom-html-68"
        }
      ]
    }
  }
